# Copy this to .env and fill in your values
# Never commit .env to git

# From @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# GitHub Personal Access Token (needs repo scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Your GitHub repo in "owner/repo" format
GITHUB_REPO=CostaFot/things

# Path to the markdown file inside the repo
GITHUB_FILE_PATH=THINGS.md

# Your Telegram user ID (message @userinfobot to get it)
ALLOWED_USER_ID=your_telegram_user_id_here

# Optional: Claude API key for auto-summaries
# Leave blank to skip AI summaries
ANTHROPIC_API_KEY=
